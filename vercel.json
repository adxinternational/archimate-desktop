{
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://archimate-desktop-production.up.railway.app/api/$1" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
