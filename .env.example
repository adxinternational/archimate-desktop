# ============================================================
# ArchiOS — Variables d'environnement
# ============================================================
# Copiez ce fichier en .env.local pour le développement.
# Sur Vercel et Railway, configurez ces variables dans les
# dashboards respectifs (Settings > Environment Variables).
# ============================================================

# ── Base de données (TiDB Cloud) ────────────────────────────
# Format : mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://root:password@gateway01.eu-central-1.prod.aws.tidbcloud.com:4000/archios?ssl={"rejectUnauthorized":true}

# ── Authentification JWT ────────────────────────────────────
# Générez une clé aléatoire forte :
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGEZ_MOI_AVEC_UNE_CLE_ALEATOIRE_FORTE

# ── Stockage fichiers (AWS S3 ou compatible) ────────────────
# Utilisez S3, Cloudflare R2, ou tout stockage compatible S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_BUCKET_NAME=archios-files

# ── IA (OpenAI) ─────────────────────────────────────────────
# Nécessaire pour les fonctionnalités de génération IA (CCTP, rapports…)
OPENAI_API_KEY=

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Vercel (rempli automatiquement par Vercel) ───────────────
# VERCEL_URL=votre-projet.vercel.app
